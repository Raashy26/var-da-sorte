<section class="historical-bets container reveal">
  <h2 class="section-title">📖 Histórico - Últimos 30 dias</h2>
  <div class="history-grid">
    {% for post in collections.apostas %}
      {% set diffDays = ((collections.apostas[0].date - post.date) / (1000*60*60*24)) | round %}
      {% if diffDays > 0 and diffDays < 30 %}
        <a href="{{ post.url }}" class="history-card">
          {{ post.date | date("dd/MM") }}
        </a>
      {% endif %}
    {% endfor %}
  </div>
</section>


<section class="cta container reveal">
  <div class="cta-wrapper" style="text-align:center; ">
    <h2>⚡ Participa nos Desafios Diários!</h2>
    <p>Transforma pequenas apostas em grandes lucros com os nossos desafios exclusivos. Acompanha a evolução e aprende com cada jogada.</p>
    <a href="/desafio/" class="btn btn-primary btn-cta">Ver Desafios</a>
  </div>
</section>

