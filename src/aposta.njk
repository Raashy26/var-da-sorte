<section class="daily-bets reveal">
  <div class="container">
    {% set apostaHoje = collections.apostas | first %}

    {% if apostaHoje %}
      <div class="bet-highlight">
        <div class="bet-info">
          <h2>🎯 Prognósticos do Dia</h2>
          <p class="date">{{ apostaHoje.date | formatDate }}</p>
          <p class="desc">Descobre as apostas mais recomendadas de hoje, baseadas em análise e estatísticas exclusivas do VAR da Sorte.</p>
          <a href="{{ apostaHoje.url }}" class="btn btn-primary">Ver Apostas de Hoje</a>
        </div>
      </div>
    {% else %}
      <p class="no-bets">⚠️ Em breve vais encontrar aqui os prognósticos do dia. Mantém-te atento!</p>
    {% endif %}
  </div>
</section>



