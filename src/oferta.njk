<script>
  const monetag = "https://otieu.com/4/10000372";
  const UTM_KEYS = ["utm_source", "utm_medium", "utm_campaign", "utm_content", "utm_term"];

  function buildTrackedOfferUrl(baseUrl) {
    const destination = new URL(baseUrl);
    const incoming = new URLSearchParams(window.location.search);

    UTM_KEYS.forEach((key) => {
      const value = incoming.get(key);
      if (value) {
        destination.searchParams.set(key, value);
      }
    });

    return destination.toString();
  }

  function abrirOferta(link) {
    const trackedLink = buildTrackedOfferUrl(link);
    window.open(trackedLink, "_blank");
    const iframe = document.createElement("iframe");
    iframe.src = monetag;
    iframe.style.display = "none";
    document.body.appendChild(iframe);
  }

  document.querySelectorAll(".betclic-cta").forEach((button) => {
    button.addEventListener("click", (e) => {
      e.preventDefault();
      const link = button.dataset.targetUrl;
      if (link) abrirOferta(link);
    });
  });
</script>

